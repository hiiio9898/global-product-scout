# ============================================================
# AI 模型配置 — 支持多供应商 / 多模型
# 使用方法：
#   1. 选择一个 ACTIVATE_PROVIDER，把其他注释掉
#   2. 在该供应商下选择一个 ACTIVATE_MODEL，把其他注释掉
#   3. 填入对应供应商的 API_KEY
# ============================================================

# --- 当前激活的供应商：deepseek / mimo ---
ACTIVATE_PROVIDER=glm

# --- 当前激活的模型 ---
ACTIVATE_MODEL=glm-5.2

# --- 供应商 1：DeepSeek ---
# 模型选项：
#   deepseek-v4-flash     (快速轻量，默认非思考模式)
#   deepseek-v4-pro       (旗舰推理，支持思考模式，价格更高)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_MODEL=deepseek-v4-pro

# --- 供应商 2：小米 MiMo ---
# 模型选项：
#   mimo-v2.5             (轻量快速模型)
#   mimo-v2.5-pro         (旗舰 Agent 模型，1T 参数 MoE)
MIMO_API_KEY=your-mimo-api-key-here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_MODEL=mimo-v2.5-pro
# MIMO_MODEL=mimo-v2-pro

# --- 抓取配置 ---
AMAZON_BEST_SELLERS_URL=https://www.amazon.com/Best-Sellers/zgbs/
SCRAPE_DELAY_SECONDS=2

# --- 汇率配置（可选，默认使用免费 API） ---
# --- ??? 3??? GLM?????? ---
#   glm-5.2               (?????????????)
#   glm-4-plus            (?????)
#   glm-4-flash           (????)
GLM_API_KEY=your-glm-api-key-here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-5.2
# GLM_MODEL=glm-4-plus

# EXCHANGE_RATE_API_KEY=your-api-key-here  # 留空则使用免费 API

# --- 数据库配置（SQLite 历史记录） ---
DATABASE_PATH=data/products.db

# --- AI 分析配置 ---
# 每批分析的产品数量（默认6，API限流时调小，追求速度调大）
ANALYSIS_BATCH_SIZE=6

# --- 中文搜索翻译（Spec 33）---
# 是否启用：输入中文自动翻译为英文搜索，结果标题翻译为中文
TRANSLATION_ENABLED=true
# 标题批量翻译每批数量（默认10）
TRANSLATION_BATCH_SIZE=10

# ============================================================
# 利润计算参数（可选覆盖，默认值见 src/platforms.py）
# ============================================================
# PROFIT_EXCHANGE_RATE=7.24
# PROFIT_COMMISSION_PCT=0.15
# PROFIT_AD_PCT=0.10
# PROFIT_SHIPPING_CNY=15.0

# ============================================================
# TikTok Shop 配置
# ============================================================

# --- TikTok 利润参数 ---
# TIKTOK_COMMISSION_PCT=0.05
# TIKTOK_PAYMENT_FEE_PCT=0.02
# TIKTOK_SHIPPING_CNY=25.0

# ============================================================
# eBay 平台配置
# ============================================================

# --- eBay 利润参数 ---
# EBAY_FINAL_VALUE_FEE_PCT=0.1325
# EBAY_LISTING_FEE_USD=0.30
# EBAY_SHIPPING_CNY=20.0
# EBAY_PACKAGING_CNY=5.0
# EBAY_PAYONEER_FEE_PCT=0.01

# ============================================================
# Scrapling 抓取引擎配置
# ============================================================

# SCRAPLING_PROXY=http://user:pass@proxy:port
SCRAPLING_BROWSER_TIMEOUT=30000
SCRAPLING_ADAPTIVE_DB=data/adaptive_elements.db
SCRAPLING_STRATEGY=fetcher_first