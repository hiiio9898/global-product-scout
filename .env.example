# ============================================================
# AI 模型配置 — 支持多供应商 / 多模型
# 使用方法：
#   1. 选择一个 ACTIVATE_PROVIDER，把其他注释掉
#   2. 在该供应商下选择一个 ACTIVATE_MODEL，把其他注释掉
#   3. 填入对应供应商的 API_KEY
# ============================================================

# --- 当前激活的供应商：deepseek / mimo / openai ---
ACTIVATE_PROVIDER=mimo

# --- 当前激活的模型 ---
ACTIVATE_MODEL=mimo-v2.5

# --- 供应商 1：DeepSeek ---
# 模型选项：
#   deepseek-v4-flash     (快速轻量，默认非思考模式)
#   deepseek-v4-pro       (旗舰推理，支持思考模式，价格更高)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_MODEL=deepseek-v4-pro

# --- 供应商 2：小米 MiMo ---
# 模型选项：
#   mimo-v2.5             (轻量快速模型)
#   mimo-v2.5-pro         (旗舰 Agent 模型，1T 参数 MoE)
MIMO_API_KEY=your-mimo-api-key-here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_MODEL=mimo-v2.5-pro
# MIMO_MODEL=mimo-v2-pro

# --- 供应商 3：OpenAI ---
# 模型选项：
#   gpt-4o               (旗舰多模态模型)
#   gpt-4o-mini           (轻量快速，性价比高)
#   gpt-3.5-turbo         (经典轻量模型)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- 抓取配置 ---
AMAZON_BEST_SELLERS_URL=https://www.amazon.com/Best-Sellers/zgbs/
SCRAPE_DELAY_SECONDS=2

# --- 数据库配置（SQLite 历史记录） ---
DATABASE_PATH=data/products.db

# ============================================================
# 利润计算参数（可选覆盖，默认值见 src/platforms.py）
# ============================================================
# PROFIT_EXCHANGE_RATE=7.24
# PROFIT_COMMISSION_PCT=0.15
# PROFIT_AD_PCT=0.10
# PROFIT_SHIPPING_CNY=15.0

# ============================================================
# 阿里巴巴国际站配置
# ============================================================

# --- 阿里巴巴利润参数 ---
# ALIBABA_COMMISSION_PCT=0.05
# ALIBABA_TRADE_ASSURANCE_PCT=0.02
# ALIBABA_SHIPPING_CNY=25.0
# ALIBABA_PACKAGING_CNY=3.0

# ============================================================
# eBay 平台配置
# ============================================================

# --- eBay 利润参数 ---
# EBAY_FINAL_VALUE_FEE_PCT=0.1325
# EBAY_LISTING_FEE_USD=0.30
# EBAY_SHIPPING_CNY=20.0
# EBAY_PACKAGING_CNY=5.0
# EBAY_PAYONEER_FEE_PCT=0.01
